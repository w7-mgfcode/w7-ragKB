# =============================================================================
# w7-ragKB — Environment Variables (Vertex AI + PostgreSQL + Slack Stack)
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.
#
# Used by docker-compose.yml to configure all three services:
#   postgres, slack-bot, rag-pipeline
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=w7ragkb

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI
# -----------------------------------------------------------------------------
# GCP project and region for Vertex AI API calls (LLM + embeddings).
# The service account key is mounted as a Docker secret from ./secrets/gcp-sa-key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# Gemini model used by the Pydantic AI agent.
# Examples: gemini-2.0-flash, gemini-2.5-flash
LLM_CHOICE=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# Model and dimensions must match the pgvector column in sql/init.sql.
# gemini-embedding-001 supports up to 3072 dimensions; 768 is the default.
EMBEDDING_MODEL_CHOICE=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# -----------------------------------------------------------------------------
# Slack (Socket Mode)
# -----------------------------------------------------------------------------
# Bot User OAuth Token (starts with xoxb-)
# Get from: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token (starts with xapp-)
# Get from: https://api.slack.com/apps → Basic Information → App-Level Tokens
# Requires connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token

# -----------------------------------------------------------------------------
# Web Frontend Auth (JWT)
# -----------------------------------------------------------------------------
# Secret key for signing JWT access tokens. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Google OAuth (optional — only needed for "Sign in with Google" on the web UI)
# Get from: https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend origin URL (used for OAuth redirects and CORS)
# In Docker Compose: http://frontend:8080 (default)
# For local dev: http://localhost:5173 (Vite dev server) or http://localhost:8080
FRONTEND_URL=http://frontend:8080

# Refresh cookie security policy:
# - true  = HTTPS only cookie (recommended for production/GCP with TLS)
# - false = allow HTTP (temporary for LAN/dev only)
COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# Web Search (choose one, leave the other empty)
# -----------------------------------------------------------------------------
# Brave Search API key — https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# SearXNG base URL (e.g., http://searxng:8080 if running in Docker)
SEARXNG_BASE_URL=

# -----------------------------------------------------------------------------
# RAG Pipeline
# -----------------------------------------------------------------------------
# Pipeline type: "local" (watch local files) or "google_drive"
RAG_PIPELINE_TYPE=local

# Run mode: "continuous" (watch loop) or "single" (one-shot, for cron)
RUN_MODE=continuous

# Unique identifier for pipeline state tracking in the database
RAG_PIPELINE_ID=prod-local-pipeline

# -----------------------------------------------------------------------------
# OpenClaw Gateway / Control Plane
# -----------------------------------------------------------------------------
# WebSocket control plane for multi-channel coordination.
CONTROL_PLANE_HOST=127.0.0.1
CONTROL_PLANE_PORT=18789

# Enable/disable the gateway module (set to false to run without multi-channel support)
GATEWAY_ENABLED=true

# -----------------------------------------------------------------------------
# Telegram Bot (optional)
# -----------------------------------------------------------------------------
# Bot token from @BotFather — https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Discord Bot (optional)
# -----------------------------------------------------------------------------
# Bot token from Discord Developer Portal — https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Document Sync Manager
# -----------------------------------------------------------------------------
# Seconds between sync status checks
SYNC_CHECK_INTERVAL=60
# Max concurrent re-indexing operations
SYNC_REINDEX_CONCURRENCY=3
# Seconds before re-indexing times out
SYNC_REINDEX_TIMEOUT=300

# -----------------------------------------------------------------------------
# Document WebSocket
# -----------------------------------------------------------------------------
# Seconds between WebSocket pings
WS_PING_INTERVAL=30
# Max WebSocket connections per user
WS_MAX_CONNECTIONS_PER_USER=5
# Max queued messages for disconnected clients
WS_MESSAGE_QUEUE_SIZE=100

# -----------------------------------------------------------------------------
# Connection Pool Tuning
# -----------------------------------------------------------------------------
# Keep these low on the e2-medium VM (4 GB RAM total).
# Used by both slack-bot and rag-pipeline services.
DB_POOL_MIN=2
DB_POOL_MAX=5
